---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import NewsletterCallout from '../components/NewsletterCallout.astro';
import { CATEGORIES } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const latest = posts.filter((post) => post.id !== featured.id).slice(0, 3);
---
<BaseLayout>
  <section class="blueprint-grid relative min-h-[calc(100svh-4.75rem)] overflow-hidden border-b border-white/10">
    <div class="absolute right-0 top-0 h-full w-1/3 bg-gradient-to-b from-signal-red/15 to-transparent"></div>
    <div class="absolute -right-28 top-20 size-[26rem] rotate-12 border-[4rem] border-white/[.025]"></div>
    <div class="container-shell relative grid min-h-[calc(100svh-4.75rem)] items-center gap-14 py-20 lg:grid-cols-[1.1fr_.9fr]">
      <div>
        <p class="eyebrow">Hong Kong Construction Knowledge</p>
        <h1 class="display-title text-balance mt-7 max-w-4xl">
          工程複雜，<br />
          <span class="bg-gradient-to-r from-signal-orange to-signal-red bg-clip-text text-transparent">可以講得簡單。</span>
        </h1>
        <p class="mt-8 max-w-2xl text-base leading-8 text-steel-300 md:text-xl md:leading-9">
          為香港工程、QS、PM 及建造業從業員整理合約、NEC、SOP、成本和地盤管理知識。少一點術語，多一點真正用得着的解釋。
        </p>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href="/blog/">開始閱讀 <span aria-hidden="true">→</span></a>
          <a class="button-secondary" href="/resources/">免費工程資源</a>
        </div>
      </div>
      <div class="relative mx-auto w-full max-w-md lg:max-w-none">
        <div class="card-surface relative aspect-[4/5] overflow-hidden p-6 md:p-8">
          <div class="flex items-center justify-between border-b border-white/10 pb-5">
            <span class="font-mono text-xs tracking-[.2em] text-steel-400">SCOPE / 001</span>
            <span class="size-3 rounded-full bg-signal-red shadow-[0_0_24px_#ff4b36]"></span>
          </div>
          <div class="mt-8 grid grid-cols-2 gap-3">
            {['QS', 'PM', 'NEC', 'SOP'].map((label, i) => (
              <div class:list={[
                'blueprint-grid grid aspect-square place-items-center border text-3xl font-black',
                i === 0 ? 'border-signal-orange/60 bg-signal-orange/10 text-signal-orange' : 'border-white/10 bg-white/[.025] text-white/35',
              ]}>{label}</div>
            ))}
          </div>
          <div class="mt-7">
            <div class="mb-3 flex items-center justify-between text-xs">
              <span class="text-steel-400">複雜度</span><span class="font-mono text-white">82 → 18</span>
            </div>
            <div class="h-1.5 bg-white/8"><div class="h-full w-4/5 bg-gradient-to-r from-signal-orange to-signal-red"></div></div>
          </div>
          <p class="absolute bottom-7 left-8 right-8 text-sm font-bold leading-6 text-steel-300">把條文、數字和現場經驗，轉成清楚的下一步。</p>
        </div>
        <div class="absolute -bottom-5 -left-5 border border-white/15 bg-ink-950 px-5 py-4 shadow-2xl">
          <p class="font-mono text-[.65rem] tracking-[.16em] text-steel-400">READERS</p>
          <p class="mt-1 text-lg font-black">工程人 / 說人話</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell py-20 md:py-28">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading eyebrow="Featured Story" title="今期重點文章" description="由常見誤解切入，把合約機制變成現場可以執行的做法。" />
      <a href="/blog/" class="text-sm font-black text-signal-orange hover:text-white">查看全部文章 →</a>
    </div>
    <div class="mt-12"><PostCard post={featured} featured /></div>
  </section>

  <section class="border-y border-white/10 bg-ink-950/55 py-20 md:py-28">
    <div class="container-shell">
      <SectionHeading eyebrow="Knowledge Map" title="你正在處理哪一類問題？" description="按工作場景找內容，不用先學懂所有術語。" />
      <div class="mt-12 grid gap-px overflow-hidden border border-white/10 bg-white/10 sm:grid-cols-2 lg:grid-cols-3">
        {CATEGORIES.map((category, index) => (
          <a href={`/category/${category.slug}/`} class="group relative bg-ink-900 p-7 transition hover:bg-ink-800 md:p-9">
            <div class="flex items-start justify-between">
              <span class="font-mono text-xs text-steel-400">0{index + 1}</span>
              <span class="text-3xl font-black text-white/12 transition group-hover:text-signal-orange">{category.code}</span>
            </div>
            <h3 class="mt-12 text-xl font-black group-hover:text-signal-orange">{category.name}</h3>
            <p class="mt-3 text-sm leading-7 text-steel-300">{category.description}</p>
            <span class="mt-7 inline-block text-sm text-white transition group-hover:translate-x-1">進入分類 →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="container-shell py-20 md:py-28">
    <SectionHeading eyebrow="Latest Articles" title="最新白話文章" description="每篇都以一個實際工作問題開始，讀完知道下一步可以做甚麼。" />
    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {latest.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="container-shell pb-20 md:pb-28">
    <NewsletterCallout />
  </section>
</BaseLayout>
