---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORIES } from '../../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="文章" description="瀏覽 BuildScope 所有香港工程、QS、PM、合約、NEC、SOP 與地盤管理文章。">
  <header class="blueprint-grid border-b border-white/10 py-16 md:py-24">
    <div class="container-shell">
      <p class="eyebrow">Knowledge Library</p>
      <h1 class="section-title mt-6">工程知識庫</h1>
      <p class="mt-5 max-w-2xl text-base leading-8 text-steel-300">從合約條文到地盤執行，把複雜問題拆成清楚、可操作的內容。</p>
    </div>
  </header>

  <section class="container-shell py-12 md:py-18">
    <div class="flex flex-col gap-5 border-b border-white/10 pb-8 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex flex-wrap gap-2" role="group" aria-label="按分類篩選文章">
        <button class="filter-button bg-signal-orange text-ink-900" data-filter="all">全部</button>
        {CATEGORIES.map((category) => (
          <button class="filter-button border border-white/15 text-steel-300 hover:border-signal-orange hover:text-white" data-filter={category.slug}>
            {category.name}
          </button>
        ))}
      </div>
      <p id="post-count" class="text-sm text-steel-400">共 {posts.length} 篇文章</p>
    </div>
    <div id="post-grid" class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <div data-post data-category={post.data.category}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
    <p id="empty-state" class="hidden py-20 text-center text-steel-300">這個分類暫時未有文章。</p>
  </section>
</BaseLayout>

<style>
  .filter-button {
    min-height: 2.75rem;
    border-radius: .2rem;
    padding: .55rem .85rem;
    font-size: .8rem;
    font-weight: 800;
    transition: .2s ease;
  }
</style>

<script>
  const buttons = [...document.querySelectorAll<HTMLButtonElement>('.filter-button')];
  const cards = [...document.querySelectorAll<HTMLElement>('[data-post]')];
  const count = document.querySelector('#post-count');
  const empty = document.querySelector('#empty-state');

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = button.dataset.filter;
      let visible = 0;
      buttons.forEach((item) => {
        const active = item === button;
        item.classList.toggle('bg-signal-orange', active);
        item.classList.toggle('text-ink-900', active);
        item.classList.toggle('border', !active);
        item.classList.toggle('border-white/15', !active);
        item.classList.toggle('text-steel-300', !active);
      });
      cards.forEach((card) => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.classList.toggle('hidden', !show);
        if (show) visible += 1;
      });
      if (count) count.textContent = `共 ${visible} 篇文章`;
      empty?.classList.toggle('hidden', visible > 0);
    });
  });
</script>
