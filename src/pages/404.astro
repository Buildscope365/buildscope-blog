---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="找不到頁面" noindex>
  <section class="blueprint-grid grid min-h-[65svh] place-items-center py-20">
    <div class="container-shell text-center">
      <p class="font-mono text-8xl font-black text-white/8">404</p>
      <h1 class="section-title -mt-5">這個工作面未移交。</h1>
      <p class="mx-auto mt-5 max-w-xl text-steel-300">你要找的頁面可能已移動、改名，或者仍在施工中。</p>
      <a href="/" class="button-primary mt-8">返回首頁 →</a>
    </div>
  </section>
</BaseLayout>
