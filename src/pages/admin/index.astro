<!doctype html>
<html lang="zh-Hant-HK">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>BuildScope 文章管理</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <noscript>
      <main style="font-family: system-ui, sans-serif; margin: 2rem; max-width: 42rem;">
        <h1>BuildScope CMS needs JavaScript</h1>
        <p>Please enable JavaScript to use the Decap CMS admin.</p>
      </main>
    </noscript>

    <script is:inline>
      const netlifySiteUrl = 'https://buildscope-blog.netlify.app';
      const browserWindow = window;

      browserWindow.BUILDSCOPE_NETLIFY_SITE_URL = netlifySiteUrl;

      const showError = (title, message) => {
        document.body.innerHTML = `
          <main style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 2rem; max-width: 44rem; line-height: 1.6;">
            <h1>${title}</h1>
            <p>${message}</p>
          </main>
        `;
      };

      const loadScript = (src) =>
        new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.src = src;
          script.onload = () => resolve();
          script.onerror = () => reject(new Error(`Failed to load ${src}`));
          document.body.appendChild(script);
        });

      loadScript('https://identity.netlify.com/v1/netlify-identity-widget.js')
        .then(() => loadScript('/netlify-identity-callback.js'))
        .then(() => {
          if (!browserWindow.netlifyIdentity) {
            throw new Error('Netlify Identity widget did not initialize');
          }

          const cmsScript = document.createElement('script');
          cmsScript.src = 'https://unpkg.com/decap-cms@^3.8.0/dist/decap-cms.js';
          cmsScript.onerror = () => {
            showError(
              'Unable to load BuildScope CMS',
              'Please refresh the page. If the issue continues, check the Decap CMS CDN or network connection.',
            );
          };
          document.body.appendChild(cmsScript);
        })
        .catch(() => {
          showError(
            'Unable to load BuildScope CMS login',
            'Please refresh the page. If the issue continues, check the Netlify Identity connection.',
          );
        });
    </script>
  </body>
</html>
