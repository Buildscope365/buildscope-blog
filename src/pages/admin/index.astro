---
---
<!doctype html>
<html lang="zh-Hant-HK">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>BuildScope 文章管理</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <noscript>
      <main style="font-family: system-ui, sans-serif; margin: 2rem; max-width: 42rem;">
        <h1>BuildScope CMS needs JavaScript</h1>
        <p>Please enable JavaScript to use the Decap CMS admin.</p>
      </main>
    </noscript>

    <script is:inline>
      const netlifySiteUrl = 'https://buildscope-blog.netlify.app';
      const browserWindow = window;
      let identityInstance;

      browserWindow.BUILDSCOPE_NETLIFY_SITE_URL = netlifySiteUrl;

      const renderLoginGate = (identity) => {
        document.body.innerHTML = `
          <main style="min-height: 100vh; display: grid; place-items: center; background: #f3f5f8; font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
            <section style="display: grid; justify-items: center; gap: 2rem;">
              <img src="/favicon.svg" alt="BuildScope" style="width: min(42vw, 300px); height: auto;" />
              <button id="buildscope-admin-login" type="button" style="border: 0; border-radius: 4px; background: #2f4147; color: white; padding: 0.7rem 1rem; box-shadow: 0 10px 22px rgba(15, 23, 42, 0.18); cursor: pointer; font: inherit;">
                Login with Netlify Identity
              </button>
              <a href="/" style="color: #7a86a1; text-decoration: none;">← Go back to site</a>
            </section>
          </main>
        `;

        document.getElementById('buildscope-admin-login')?.addEventListener('click', () => {
          browserWindow.__buildscopeAdminLoginGateClicked = true;
          identity.open('login');
        });
      };

      const showError = (title, message) => {
        document.body.innerHTML = `
          <main style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 2rem; max-width: 44rem; line-height: 1.6;">
            <h1>${title}</h1>
            <p>${message}</p>
          </main>
        `;
      };

      const loadScript = (src) =>
        new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.src = src;
          script.onload = () => resolve();
          script.onerror = () => reject(new Error(`Failed to load ${src}`));
          document.body.appendChild(script);
        });

      const resolveIdentity = (candidate) => {
        if (candidate?.open) return candidate;
        if (candidate?.default?.open) return candidate.default;
        if (candidate?.netlifyIdentity?.open) return candidate.netlifyIdentity;
        return undefined;
      };

      const loadCMS = () => {
        const cmsScript = document.createElement('script');
        cmsScript.src = 'https://unpkg.com/decap-cms@^3.8.0/dist/decap-cms.js';
        cmsScript.onerror = () => {
          showError(
            'Unable to load BuildScope CMS',
            'Please refresh the page. If the issue continues, check the Decap CMS CDN or network connection.',
          );
        };
        document.body.appendChild(cmsScript);
      };

      loadScript('https://identity.netlify.com/v1/netlify-identity-widget.js')
        .then(() => {
          identityInstance = resolveIdentity(browserWindow.netlifyIdentity) || browserWindow.netlifyIdentity;
          browserWindow.BUILDSCOPE_NETLIFY_IDENTITY = identityInstance;
          return loadScript('/netlify-identity-callback.js');
        })
        .then(() => {
          if (
            !resolveIdentity(identityInstance) &&
            !resolveIdentity(browserWindow.netlifyIdentity) &&
            !resolveIdentity(browserWindow.BUILDSCOPE_NETLIFY_IDENTITY)
          ) {
            throw new Error('Netlify Identity widget did not initialize');
          }

          const identity = resolveIdentity(identityInstance) ||
            resolveIdentity(browserWindow.netlifyIdentity) ||
            resolveIdentity(browserWindow.BUILDSCOPE_NETLIFY_IDENTITY);

          browserWindow.netlifyIdentity = identity;
          browserWindow.BUILDSCOPE_NETLIFY_IDENTITY = identity;

          identity.on('login', () => {
            identity.close();
            browserWindow.location.reload();
          });

          window.setTimeout(() => {
            if (identity.currentUser?.()) {
              loadCMS();
            } else {
              renderLoginGate(identity);
            }
          }, 300);
        })
        .catch(() => {
          showError(
            'Unable to load BuildScope CMS login',
            'Please refresh the page. If the issue continues, check the Netlify Identity connection.',
          );
        });
    </script>
  </body>
</html>
