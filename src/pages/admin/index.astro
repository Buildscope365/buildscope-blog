<!doctype html>
<html lang="zh-Hant-HK">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>BuildScope 文章管理</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <noscript>
      <main style="font-family: system-ui, sans-serif; margin: 2rem; max-width: 42rem;">
        <h1>BuildScope CMS needs JavaScript</h1>
        <p>Please enable JavaScript to use the Decap CMS admin.</p>
      </main>
    </noscript>

    <script>
      import netlifyIdentity from 'netlify-identity-widget';

      const netlifySiteUrl = 'https://buildscope-blog.netlify.app';
      const browserWindow = window as Window & {
        BUILDSCOPE_NETLIFY_SITE_URL?: string;
        netlifyIdentity?: unknown;
      };

      browserWindow.BUILDSCOPE_NETLIFY_SITE_URL = netlifySiteUrl;
      browserWindow.netlifyIdentity = netlifyIdentity;

      const callbackScript = document.createElement('script');
      callbackScript.src = '/netlify-identity-callback.js';
      callbackScript.onload = () => {
        const cmsScript = document.createElement('script');
        cmsScript.src = 'https://unpkg.com/decap-cms@^3.8.0/dist/decap-cms.js';
        cmsScript.onerror = () => {
          document.body.innerHTML = `
            <main style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 2rem; max-width: 44rem; line-height: 1.6;">
              <h1>Unable to load BuildScope CMS</h1>
              <p>Please refresh the page. If the issue continues, check the Decap CMS CDN or network connection.</p>
            </main>
          `;
        };
        document.body.appendChild(cmsScript);
      };
      callbackScript.onerror = () => {
        document.body.innerHTML = `
          <main style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 2rem; max-width: 44rem; line-height: 1.6;">
            <h1>Unable to load BuildScope CMS login</h1>
            <p>Please refresh the page. If the issue continues, check the local Identity callback script.</p>
          </main>
        `;
      };
      document.body.appendChild(callbackScript);
    </script>
  </body>
</html>
