---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  image = '/og-default.svg',
  type = 'website',
  publishedTime,
  noindex = false,
} = Astro.props;
const pageTitle = title ? `${title} | ${SITE.shortName}` : `${SITE.name}｜香港工程知識平台`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url);
const socialImage = new URL(image, Astro.site ?? SITE.url);
---
<!doctype html>
<html lang="zh-Hant-HK">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#081526" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="zh_HK" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
    <script is:inline>
      window.BUILDSCOPE_NETLIFY_SITE_URL = 'https://buildscope-blog.netlify.app';
    </script>
    <script>
      import * as netlifyIdentityModule from 'netlify-identity-widget';

      const browserWindow = window as Window & {
        netlifyIdentity?: unknown;
      };
      const netlifyIdentity = netlifyIdentityModule.default ?? netlifyIdentityModule;
      browserWindow.netlifyIdentity = netlifyIdentity;

      const callbackScript = document.createElement('script');
      callbackScript.src = '/netlify-identity-callback.js';
      document.body.appendChild(callbackScript);
    </script>
  </body>
</html>
