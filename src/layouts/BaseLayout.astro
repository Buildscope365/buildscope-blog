---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  image = '/og-default.svg',
  type = 'website',
  publishedTime,
  noindex = false,
} = Astro.props;
const pageTitle = title ? `${title} | ${SITE.shortName}` : `${SITE.name}｜香港工程知識平台`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url);
const socialImage = new URL(image, Astro.site ?? SITE.url);
---
<!doctype html>
<html lang="zh-Hant-HK">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#081526" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="zh_HK" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => {
          if (!user && window.location.hash.startsWith('#')) {
            window.netlifyIdentity.open();
          }
        });
        window.netlifyIdentity.on('login', () => {
          if (window.location.pathname !== '/admin/') {
            window.location.href = '/admin/';
          }
        });
      }
    </script>
  </body>
</html>
